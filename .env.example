# Telethon (https://my.telegram.org/apps)
API_ID=
API_HASH=

# BotFather token (used by Telethon for bot login AND by aiohttp for sendMessageDraft / createForumTopic)
BOT_TOKEN=

# Comma-separated allow-list of Telegram user_ids that may use the bot.
ALLOWED_USER_IDS=

# Path to the Claude Code CLI binary.
CLAUDE_BIN=/root/.local/bin/claude

# Initial cwd for new sessions; user can override per-session with /cd.
DEFAULT_CWD=/opt/tg_interface

# Idle suspend window for claude subprocesses, in seconds.
IDLE_SUSPEND_SEC=600

# Space-separated tools the subprocess is allowed to call without prompting.
ALLOWED_TOOLS=Bash Read Write Edit Glob Grep

# SQLite path.
DB_PATH=/opt/tg_interface/state.db

# Per-user data root. Each Telegram user gets an isolated HOME at
# <DATA_DIR>/users/<tg_user_id>/home that becomes the credential dir for
# their `claude` subprocesses.
DATA_DIR=/var/lib/claude-bridge
